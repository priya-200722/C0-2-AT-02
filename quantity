#include <iostream>
using namespace std;

class Warehouse {
private:
    int itemID, quantity;
    string name, location;
    static int totalItems;

public:
    void input() {
        cout << "\nEnter Item ID: ";
        cin >> itemID;
        cout << "Enter Item Name: ";
        cin >> name;

        do {
            cout << "Enter Quantity (>0): ";
            cin >> quantity;
        } while (quantity <= 0);

        cout << "Enter Location: ";
        cin >> location;

        totalItems++;
    }

    void display() {
        cout << "\nItem ID: " << itemID;
        cout << "\nName: " << name;
        cout << "\nQuantity: " << quantity;
        cout << "\nLocation: " << location << endl;
    }

    static void showTotal() {
        cout << "\nTotal Items: " << totalItems << endl;
    }
};

int Warehouse::totalItems = 0;

int main() {
    int n;
    cout << "Enter number of items: ";
    cin >> n;

    Warehouse w[n];

    for (int i = 0; i < n; i++)
        w[i].input();

    for (int i = 0; i < n; i++)
        w[i].display();

    Warehouse::showTotal();
    return 0;
}
